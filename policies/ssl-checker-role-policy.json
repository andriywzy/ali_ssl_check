{
  "Version": "1",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": [
        "oss:GetObject",
        "oss:PutObject"
      ],
      "Resource": [
        "acs:oss:*:*:<your-bucket>",
        "acs:oss:*:*:<your-bucket>/<your-prefix>/*"
      ]
    },
    {
      "Effect": "Allow",
      "Action": [
        "log:PostLogStoreLogs"
      ],
      "Resource": [
        "acs:log:*:*:project/<log-project>/logstore/<log-logstore>"
      ]
    }
  ]
}
